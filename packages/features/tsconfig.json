{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"noEmit": true,
		"paths": {
			"api": ["../../apps/api/src/public.ts"],
			"contracts": ["../../contracts/src/index.ts"]
		}
	},
	"include": ["src"],
	"references": [{ "path": "../../apps/api" }, { "path": "../../contracts" }]
}
