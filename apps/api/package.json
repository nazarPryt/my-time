{
	"name": "api",
	"version": "1.0.50",
	"scripts": {
		"test": "bun test --env-file .env.test",
		"test:db:up": "docker compose -f ../../docker-compose.test.yml up -d --wait",
		"test:db:down": "docker compose -f ../../docker-compose.test.yml down",
		"test:ci": "bun run test:db:up && bun test --env-file .env.test; bun run test:db:down",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/jwt": "latest",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"elysia": "latest",
		"postgres": "^3.4.8",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@elysiajs/eden": "latest",
		"bun-types": "latest",
		"drizzle-kit": "^0.31.9"
	},
	"module": "src/index.js"
}
