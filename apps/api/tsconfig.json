{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "node",
		"baseUrl": "./",
		"paths": {
			"@/*": ["src/*"],
			"@db": ["src/db/index.ts"],
			"@db/*": ["src/db/*"],
			"@features/*": ["src/features/*"],
			"@shared/*": ["src/shared/*"]
		},
		"types": ["bun-types"],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	}
}
