{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./*"],
			"api": ["../../apps/api/src/public.ts"],
			"contracts": ["../../contracts/src/index.ts"],
			"features": ["../../packages/features/src/index.ts"],
			"features/workout": ["../../packages/features/src/workout/index.ts"]
		}
	},
	"references": [{ "path": "../../apps/api" }, { "path": "../../contracts" }],
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
